---
interface Props {
  currentSite: string;
  cluster: string;
}

import { NETWORK_CLUSTERS } from '../data/network-clusters';

const { currentSite, cluster } = Astro.props;
const clusterData = NETWORK_CLUSTERS[cluster];
if (!clusterData) return;
const siblings = clusterData.sites.filter(s => s.label !== currentSite);
if (siblings.length === 0) return;
---

<aside class="network-crosslinks">
  <p class="network-crosslinks-label">More {clusterData.name} guides from our network</p>
  <div class="network-crosslinks-grid">
    {siblings.map(site => (
      <a href={site.url} class="network-crosslinks-link" rel="noopener">
        Discover {site.label}
      </a>
    ))}
  </div>
</aside>

<style>
  .network-crosslinks {
    border-top: 1px solid var(--color-sand-dark, #EBE4D8);
    padding: var(--space-6, 1.5rem) 0;
    margin: var(--space-8, 2rem) 0 0 0;
  }
  .network-crosslinks-label {
    font-size: 0.78rem;
    font-weight: var(--weight-semibold, 600);
    color: var(--color-slate, #6B7280);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-3, 0.75rem);
  }
  .network-crosslinks-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 0.5rem);
  }
  .network-crosslinks-link {
    font-size: 0.82rem;
    font-weight: var(--weight-medium, 500);
    color: var(--color-ocean-teal, #0D7377);
    text-decoration: none;
    background: rgba(13, 115, 119, 0.07);
    border: 1px solid rgba(13, 115, 119, 0.15);
    border-radius: 20px;
    padding: 4px 12px;
    transition: background 0.15s ease;
  }
  .network-crosslinks-link:hover {
    background: rgba(13, 115, 119, 0.14);
  }
</style>
