---
import FTCDisclosure from './FTCDisclosure.astro';

interface Props {
  destination: string;
  slug: string;
}
const { destination, slug } = Astro.props;
---

<section class="complete-trip-footer">
  <div class="trip-footer-inner">
    <h2>Ready to Plan Your {destination} Trip?</h2>
    <p>Tell our AI planner your dates and budget — it builds your full itinerary with hotels, tours, and transport.</p>
    <a href="/plan/" class="trip-planner-cta">Plan My {destination} Trip &rarr;</a>
    <span class="trip-footer-note">Free during beta &middot; No account needed</span>
  </div>
</section>

<style>
  .complete-trip-footer {
    margin: 3rem 0;
    text-align: center;
  }
  .trip-footer-inner {
    background: linear-gradient(135deg, rgba(var(--card-rgb, 17, 24, 39), 1) 0%, rgba(var(--bg-rgb, 13, 19, 33), 1) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 2.5rem;
  }
  .trip-footer-inner h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .trip-footer-inner p {
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .trip-planner-cta {
    display: inline-block;
    padding: 1rem 2rem;
    background: var(--accent-gold, #d4a843);
    color: var(--bg-dark, #0a0f1a);
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .trip-planner-cta:hover {
    opacity: 0.9;
  }
  .trip-footer-note {
    display: block;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted, #64748b);
  }
</style>
